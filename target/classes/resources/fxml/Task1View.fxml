<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="600.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Task1Controller">
    <top>
        <Label alignment="CENTER" prefHeight="50.0" prefWidth="700.0"
               style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
               text="ЗАДАНИЕ 1: Массив с N максимальными значениями" BorderPane.alignment="CENTER">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="15.0" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="Размер массива:"/>
                        <Slider fx:id="sizeSlider" blockIncrement="5.0" majorTickUnit="10.0"
                                max="50.0" min="10.0" minorTickCount="4" showTickLabels="true"
                                showTickMarks="true" snapToTicks="true" value="20.0"/>
                        <TextField fx:id="sizeField" editable="false" prefWidth="50.0"
                                   text="20"/>
                    </children>
                </HBox>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label text="N (кол-во макс. значений):"/>
                        <Slider fx:id="nSlider" blockIncrement="1.0" majorTickUnit="1.0"
                                max="10.0" min="1.0" showTickLabels="true" showTickMarks="true"
                                snapToTicks="true" value="5.0"/>
                        <TextField fx:id="nField" editable="false" prefWidth="50.0" text="5"/>
                    </children>
                </HBox>
                <Button fx:id="btnGenerate" mnemonicParsing="false"
                        onAction="#handleGenerateButton" prefHeight="40.0" prefWidth="200.0"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                        text="Сгенерировать массив"/>
                <ScrollPane prefHeight="200.0" prefWidth="650.0">
                    <content>
                        <TextArea fx:id="originalArrayArea" editable="false" prefHeight="180.0"
                                  prefWidth="630.0" wrapText="true"/>
                    </content>
                </ScrollPane>
                <Button fx:id="btnFindMax" mnemonicParsing="false"
                        onAction="#handleFindMaxButton" prefHeight="40.0" prefWidth="200.0"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"
                        text="Найти N максимальных"/>
                <ScrollPane prefHeight="150.0" prefWidth="650.0">
                    <content>
                        <TextArea fx:id="resultArea" editable="false" prefHeight="130.0"
                                  prefWidth="630.0" wrapText="true"/>
                    </content>
                </ScrollPane>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Label fx:id="statsLabel" text="Статистика: "/>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>
        </VBox>
    </center>
    <bottom>
        <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBackButton"
                prefHeight="40.0" prefWidth="150.0"
                style="-fx-background-color: #f44336; -fx-text-fill: white;"
                text="Назад в меню" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="15.0"/>
            </BorderPane.margin>
        </Button>
    </bottom>
</BorderPane>