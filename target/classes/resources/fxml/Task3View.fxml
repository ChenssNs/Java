<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="700.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Task3Controller">
    <top>
        <Label alignment="CENTER" prefHeight="50.0" prefWidth="800.0"
               style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"
               text="ЗАДАНИЕ 3: Управление студентами" BorderPane.alignment="CENTER" />
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Список студентов">
                    <content>
                        <VBox spacing="10.0">
                            <children>
                                <TableView fx:id="studentTable" prefHeight="300.0" prefWidth="780.0">
                                    <columns>
                                        <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
                                        <TableColumn fx:id="lastNameColumn" prefWidth="100.0" text="Фамилия" />
                                        <TableColumn fx:id="firstNameColumn" prefWidth="100.0" text="Имя" />
                                        <TableColumn fx:id="groupColumn" prefWidth="80.0" text="Группа" />
                                        <TableColumn fx:id="markColumn" prefWidth="80.0" text="Оценка" />
                                        <TableColumn fx:id="egeColumn" prefWidth="80.0" text="ЕГЭ" />
                                    </columns>
                                </TableView>

                                <!-- Панель с кнопками управления -->
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnRefresh" mnemonicParsing="false"
                                                onAction="#handleRefreshButton"
                                                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                                                text="Обновить" />
                                        <Button fx:id="btnSortByEge" mnemonicParsing="false"
                                                onAction="#handleSortByEgeButton"
                                                style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                                                text="Сортировать по ЕГЭ" />
                                        <Button fx:id="btnDelete" mnemonicParsing="false"
                                                onAction="#handleDeleteStudentButton"
                                                style="-fx-background-color: #f44336; -fx-text-fill: white;"
                                                text="Удалить выбранного" />
                                    </children>
                                </HBox>

                                <Label fx:id="countLabel" text="Всего студентов: 5" style="-fx-text-fill: white;" />
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Добавить студента">
                    <content>
                        <VBox spacing="15.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="№ зачетки:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newIdField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Фамилия:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newLastNameField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Имя:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newFirstNameField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Группа:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newGroupField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Кафедра:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newDepartmentField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Дисциплина:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newDisciplineField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Оценка:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newMarkField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Преподаватель:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newTeacherField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="ЕГЭ:" prefWidth="100" style="-fx-text-fill: black;" />
                                        <TextField fx:id="newEgeField" prefWidth="200" />
                                    </children>
                                </HBox>
                                <Button fx:id="btnAddStudent" mnemonicParsing="false"
                                        onAction="#handleAddStudentButton"
                                        style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;"
                                        text="Добавить студента" />
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Файлы">
                    <content>
                        <VBox alignment="CENTER" spacing="20.0">
                            <children>
                                <HBox alignment="CENTER" spacing="20.0">
                                    <children>
                                        <Button fx:id="btnSaveJson" mnemonicParsing="false"
                                                onAction="#handleSaveJsonButton" prefHeight="50.0" prefWidth="150.0"
                                                style="-fx-background-color: #2196F3; -fx-text-fill: white;"
                                                text="Сохранить в JSON" />
                                        <Button fx:id="btnLoadJson" mnemonicParsing="false"
                                                onAction="#handleLoadJsonButton" prefHeight="50.0" prefWidth="150.0"
                                                style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                                                text="Загрузить из JSON" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="fileStatusArea" editable="false" prefHeight="150.0"
                                          prefWidth="600.0" wrapText="true"
                                          style="-fx-control-inner-background: #2a2a2a; -fx-text-fill: white;" />
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBackButton"
                prefHeight="40.0" prefWidth="150.0"
                style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 14px;"
                text="Назад в меню" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="15.0" />
            </BorderPane.margin>
        </Button>
    </bottom>
</BorderPane>