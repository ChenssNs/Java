<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="700.0" prefWidth="800.0"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Task3Controller">
    <top>
        <Label alignment="CENTER" prefHeight="50.0" prefWidth="800.0"
               style="-fx-background-color: #FF9800; -fx-text-fill: white;"
               text="ЗАДАНИЕ 3: Управление студентами" BorderPane.alignment="CENTER">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Список студентов">
                    <content>
                        <VBox spacing="10.0">
                            <children>
                                <TableView fx:id="studentTable" prefHeight="300.0" prefWidth="780.0">
                                    <columns>
                                        <TableColumn fx:id="idColumn" prefWidth="75.0" text="ID" />
                                        <TableColumn fx:id="lastNameColumn" prefWidth="100.0" text="Фамилия" />
                                        <TableColumn fx:id="firstNameColumn" prefWidth="100.0" text="Имя" />
                                        <TableColumn fx:id="groupColumn" prefWidth="80.0" text="Группа" />
                                        <TableColumn fx:id="markColumn" prefWidth="80.0" text="Оценка" />
                                        <TableColumn fx:id="egeColumn" prefWidth="80.0" text="ЕГЭ" />
                                    </columns>
                                </TableView>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <Button fx:id="btnRefresh" mnemonicParsing="false"
                                                onAction="#handleRefreshButton" text="Обновить" />
                                        <Button fx:id="btnSortByEge" mnemonicParsing="false"
                                                onAction="#handleSortByEgeButton"
                                                style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                                                text="Сортировать по ЕГЭ" />
                                    </children>
                                </HBox>
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="Добавить студента">
                    <content>
                        <GridPane hgap="10.0" vgap="10.0">
                            <children>
                                <Label text="№ зачетки:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <TextField fx:id="newIdField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                                <Label text="Фамилия:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <TextField fx:id="newLastNameField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                                <Label text="Имя:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <TextField fx:id="newFirstNameField" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                                <Label text="Группа:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                <TextField fx:id="newGroupField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

                                <Label text="Кафедра:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                <TextField fx:id="newDepartmentField" GridPane.columnIndex="1" GridPane.rowIndex="4" />

                                <Label text="Дисциплина:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                <TextField fx:id="newDisciplineField" GridPane.columnIndex="1" GridPane.rowIndex="5" />

                                <Label text="Оценка:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                <TextField fx:id="newMarkField" GridPane.columnIndex="1" GridPane.rowIndex="6" />

                                <Label text="Преподаватель:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                <TextField fx:id="newTeacherField" GridPane.columnIndex="1" GridPane.rowIndex="7" />

                                <Label text="ЕГЭ:" GridPane.columnIndex="0" GridPane.rowIndex="8" />
                                <TextField fx:id="newEgeField" GridPane.columnIndex="1" GridPane.rowIndex="8" />

                                <Button fx:id="btnAddStudent" mnemonicParsing="false"
                                        onAction="#handleAddStudentButton"
                                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                                        text="Добавить студента" GridPane.columnIndex="1" GridPane.rowIndex="9" />
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </GridPane>
                    </content>
                </Tab>
                <Tab text="Файлы">
                    <content>
                        <VBox alignment="CENTER" spacing="20.0">
                            <children>
                                <HBox alignment="CENTER" spacing="20.0">
                                    <children>
                                        <Button fx:id="btnSaveJson" mnemonicParsing="false"
                                                onAction="#handleSaveJsonButton" prefHeight="50.0" prefWidth="150.0"
                                                style="-fx-background-color: #2196F3; -fx-text-fill: white;"
                                                text="Сохранить в JSON" />
                                        <Button fx:id="btnLoadJson" mnemonicParsing="false"
                                                onAction="#handleLoadJsonButton" prefHeight="50.0" prefWidth="150.0"
                                                style="-fx-background-color: #FF9800; -fx-text-fill: white;"
                                                text="Загрузить из JSON" />
                                    </children>
                                </HBox>
                                <TextArea fx:id="fileStatusArea" editable="false" prefHeight="150.0"
                                          prefWidth="600.0" wrapText="true" />
                            </children>
                            <padding>
                                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                            </padding>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <bottom>
        <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBackButton"
                prefHeight="40.0" prefWidth="150.0"
                style="-fx-background-color: #f44336; -fx-text-fill: white;"
                text="Назад в меню" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="15.0" />
            </BorderPane.margin>
        </Button>
    </bottom>
</BorderPane>